# Copy to secret.yaml, fill in values from Terraform outputs, then apply.
# Or run: ./scripts/create-k8s-secret.sh
#
#   terraform output -raw rds_endpoint
#   terraform output -raw msk_bootstrap_brokers
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: romanstream
type: Opaque
stringData:
  DB_HOST: "REPLACE_WITH_RDS_ENDPOINT"
  DB_USER: "marvin_user"
  DB_PASS: "REPLACE_WITH_STRONG_PASSWORD"
  KAFKA_BOOTSTRAP_SERVERS: "REPLACE_WITH_MSK_BOOTSTRAP_BROKERS"
